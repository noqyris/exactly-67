default_platform(:ios)

# App Store Connect API key — provide these via env before running:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH (path to the AuthKey_XXXX.p8)
def asc_api_key
  # set_spaceship_token so the older produce/tunes actions authenticate too.
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    in_house: false,
    set_spaceship_token: true,
  )
end

APP_NAME = "Exactly 67: Number Puzzle"

# Register the bundle id (Developer Portal) and create the App Store Connect
# record directly via Spaceship ConnectAPI — produce needs an Apple ID login,
# but the API-key token drives ConnectAPI fine.
def ensure_app_exists(_key)
  require "spaceship"

  existing = (Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_ID } rescue nil)
  if existing.nil?
    Spaceship::ConnectAPI::BundleId.create(name: "Exactly 67", identifier: APP_ID, platform: "IOS")
    UI.success("Registered bundle id #{APP_ID}")
  else
    UI.message("Bundle id #{APP_ID} already registered.")
  end

  app = (Spaceship::ConnectAPI::App.find(APP_ID) rescue nil)
  if app.nil?
    Spaceship::ConnectAPI::App.create(
      name: APP_NAME,
      version_string: "1.0.0",
      sku: "exactly67",
      primary_locale: "en-US",
      bundle_id: APP_ID,
      platforms: ["IOS"],
    )
    UI.success("Created App Store Connect record: #{APP_NAME}")
  else
    UI.message("App record already exists (#{app.name}).")
  end
end

TEAM = "YMN45WC2QR"
APP_ID = "com.noqyris.exactly67"

def build_ipa
  update_code_signing_settings(
    use_automatic_signing: true,
    team_id: TEAM,
    path: "App.xcodeproj",
    targets: ["App"],
  )
  build_app(
    project: "App.xcodeproj",
    scheme: "App",
    configuration: "Release",
    export_method: "app-store",
    output_directory: "./build",
    output_name: "Exactly67.ipa",
    xcargs: "-allowProvisioningUpdates",
    clean: true,
  )
end

platform :ios do
  desc "Verify auth + create the App Store Connect app record only"
  lane :create_app do
    ensure_app_exists(asc_api_key)
  end

  desc "Build + sign the store IPA only (no app record / upload needed)"
  lane :build_only do
    asc_api_key
    build_ipa
  end

  desc "Full pipeline: create app record, build+sign, upload build, push metadata+screenshots, submit for review"
  lane :release do
    key = asc_api_key

    # 1. Make sure the app exists in App Store Connect (no-op if it already does).
    ensure_app_exists(key)

    # 2. Build a signed, store-ready IPA (Xcode + the API key create the
    #    provisioning profile automatically via -allowProvisioningUpdates).
    build_ipa

    # 3. Upload the build, all metadata and screenshots, then submit for review.
    upload_to_app_store(
      api_key: key,
      app_identifier: APP_ID,
      force: true, # skip the HTML metadata preview/confirm
      run_precheck_before_submit: true,
      submit_for_review: true,
      automatic_release: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
      },
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
    )
  end

  desc "Upload the already-built IPA + metadata + screenshots, wait for processing, submit for review"
  lane :finish do
    key = asc_api_key
    upload_to_app_store(
      api_key: key,
      app_identifier: APP_ID,
      ipa: "build/Exactly67.ipa",
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: true,
      automatic_release: true,
      wait_for_uploaded_build: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
      },
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
    )
  end

  desc "Set age rating + attach the processed build + submit for review (text/screenshots already pushed)"
  lane :submit do
    key = asc_api_key
    upload_to_app_store(
      api_key: key,
      app_identifier: APP_ID,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: true,
      automatic_release: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
      },
      metadata_path: "./fastlane/metadata",
    )
  end

  desc "Upload only the screenshots (metadata/text pushed separately via API)"
  lane :screenshots do
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true,
      submit_for_review: false,
      screenshots_path: "./fastlane/screenshots",
    )
  end

  desc "Upload only metadata + screenshots (no build, no submit) — safe dry-ish run to validate the listing"
  lane :metadata do
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      skip_binary_upload: true,
      force: true,
      submit_for_review: false,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
    )
  end

  desc "Build + upload the binary only (no metadata, no submit) — lands a build in TestFlight"
  lane :build_and_upload do
    key = asc_api_key
    build_ipa
    upload_to_app_store(
      api_key: key,
      app_identifier: APP_ID,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
    )
  end
end
